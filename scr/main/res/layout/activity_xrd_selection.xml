<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/white"
    android:padding="0dp">

    <!-- Container for cards -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">

        <!-- Card 1: Pale Green - XRD M IDENTIFICATION -->
        <LinearLayout
            android:id="@+id/btnXrdMIdentification"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@color/card_pale_green"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="XRD M Identification"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_black"
                android:gravity="center"
                android:fontFamily="sans-serif" />

        </LinearLayout>

        <!-- Card 2: Light Green - XRD d(A) IDENTIFICATION -->
        <LinearLayout
            android:id="@+id/btnXrdDIdentification"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@color/card_light_green"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="XRD d(A) Identification Single-phase"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_black"
                android:gravity="center"
                android:fontFamily="sans-serif" />

        </LinearLayout>

        <!-- Card 3: Mint Green - XRD ONE PEAK IDENTIFICATION -->
        <LinearLayout
            android:id="@+id/btnXrdOnePeakIdentification"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@color/card_mint_green"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="XRD One Peak Identification"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_black"
                android:gravity="center"
                android:fontFamily="sans-serif" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>

