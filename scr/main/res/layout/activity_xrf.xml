<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="XRF Energy Lookup"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingBottom="16dp"/>

    <EditText
        android:id="@+id/etElementSymbol"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Enter element symbol (e.g., Fe, Cu, Au)"
        android:inputType="text"/>

    <Button
        android:id="@+id/btnSearchElement"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Search Element"
        android:layout_marginTop="8dp"/>

    <TextView
        android:id="@+id/tvXrfSources"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="XRF Sources: xrf_data.xlsx, xrf_data.csv"
        android:textSize="12sp"
        android:textColor="#666666"
        android:layout_marginTop="8dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvEnergyData"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:padding="8dp"/>

            <TextView
                android:id="@+id/tvTimeToResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Time to First Result: ---"
                android:textSize="12sp"
                android:textStyle="italic"
                android:gravity="center"
                android:layout_marginTop="16dp"
                android:padding="8dp"
                android:textColor="#666666" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>

